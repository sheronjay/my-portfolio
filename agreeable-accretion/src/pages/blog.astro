---
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Sidebar from '../components/Sidebar.astro';
import BlogEntry from '../components/BlogEntry.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { formatMonthYear, getContentCollection, sortBlogPosts } from '../utils/content';

const title = 'Blog — Sheron Jayasinghe';
const description = 'Writings on robotics, IoT, embedded systems, and mathematics.';
const posts = sortBlogPosts(await getContentCollection('blog'));
const emptyMessage = 'Sheron is too lazy to update this section. you will see them once he updates it';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div id="wrapper">
      <SiteHeader activePage="blog" />

      <div id="content-area">
        <!-- Main column -->
        <div id="main-column">
          <p class="issue-line">BLOG &mdash; ALL ARTICLES</p>

          <div class="section-heading">Articles</div>

          {posts.length > 0 ? (
            posts.map((post) => (
              <BlogEntry
                title={post.data.title}
                author={post.data.author}
                date={formatMonthYear(post.data.publishDate)}
                href={`/blog/${post.slug}`}
                excerpt={post.data.excerpt}
                tags={post.data.tags}
              />
            ))
          ) : (
            <p class="empty-state">{emptyMessage}</p>
          )}
        </div>

        <!-- Sidebar -->
        <Sidebar />
      </div>

      <SiteFooter />
    </div>
  </body>
</html>

---
import BaseHead from '../components/BaseHead.astro';

const title = 'Blog';
const description = 'Blog page for Sheron Jayasinghe.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<main class="page-shell">
			<nav aria-label="Primary">
				<a href="https://www.linkedin.com/in/sheron-jayasinghe-54317934a" target="_blank" rel="noreferrer">
					LinkedIn
				</a>
				<a href="/blog">blog</a>
				<a href="/cv/CV - Sheron Jayasinghe.pdf" target="_blank" rel="noreferrer">cv</a>
				<a href="https://github.com/sheronjay" target="_blank" rel="noreferrer">github</a>
			</nav>

			<section class="blog-placeholder">
				<h1>Blog</h1>
				<p>This page is linked from the current portfolio navigation.</p>
				<p>There was no legacy `blog.html` file in the repo, so this route keeps the navigation valid.</p>
			</section>
		</main>
	</body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Sidebar from '../components/Sidebar.astro';
import BlogEntry from '../components/BlogEntry.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getCollection } from 'astro:content';
import { formatMonthYear, sortBlogPosts } from '../utils/content';

const title = 'Blog — Sheron Jayasinghe';
const description = 'Writings on robotics, IoT, embedded systems, and mathematics.';
const posts = sortBlogPosts(await getCollection('blog'));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div id="wrapper">
      <SiteHeader activePage="blog" />

      <div id="content-area">
        <!-- Main column -->
        <div id="main-column">
          <p class="issue-line">BLOG &mdash; ALL ARTICLES</p>

          <div class="section-heading">Articles</div>

          {posts.map((post) => (
            <BlogEntry
              title={post.data.title}
              author={post.data.author}
              date={formatMonthYear(post.data.publishDate)}
              href={`/blog/${post.slug}`}
              excerpt={post.data.excerpt}
              tags={post.data.tags}
            />
          ))}
        </div>

        <!-- Sidebar -->
        <Sidebar />
      </div>

      <SiteFooter />
    </div>
  </body>
</html>

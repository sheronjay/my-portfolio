---
interface Props {
  title: string;
  href?: string;
  author?: string;
  authorHref?: string;
  date?: string;
  tags?: string[];
  excerpt: string;
}

const { title, href = '#', author, authorHref, date, tags = [], excerpt } = Astro.props;
---

<div class="entry">
  <h2><a href={href}>{title}</a></h2>
  {(author || date) && (
    <div class="byline">
      {author && (
        <>
          by{' '}
          {authorHref ? <a href={authorHref}>{author}</a> : <span>{author}</span>}
        </>
      )}
      {author && date && ' — '}
      {date && <span>{date}</span>}
    </div>
  )}
  <p>{excerpt}</p>
  {tags.length > 0 && (
    <div class="entry-tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</div>
